services:
  guacamole:
    image: {{ guacamole_image }}
    container_name: guacamole
    restart: unless-stopped
    volumes:
      - guacamole_config:/config
      - /etc/localtime:/etc/localtime:ro
    environment:
      TZ: "{{ guacamole_timezone }}"
      EXTENSIONS: "auth-totp"
    networks:
      {{ traefik_network_name }}:
        ipv4_address: {{ guacamole_ip }}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.guacamole.rule=Host(`{{ guacamole_domain }}`)"
      - "traefik.http.routers.guacamole.entrypoints=https"
      - "traefik.http.routers.guacamole.tls.certresolver=cloudflare"
      - "traefik.http.services.guacamole.loadbalancer.server.port={{ guacamole_port }}"

volumes:
  guacamole_config:

networks:
  {{ traefik_network_name }}:
    external: true
